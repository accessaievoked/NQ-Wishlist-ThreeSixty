# Copy this file to .env and fill in your values.
# Then add these as Environment Variables in your Vercel project dashboard.

# Your Shopify store URL (without https://)
SHOPIFY_STORE_URL=yourstore.myshopify.com

# Admin API access token from your Shopify Custom App
# Required scopes: write_metaobject_definitions, write_metaobjects, read_metaobjects
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Your Shopify storefront URL — used for CORS (prevents other sites from using your API)
ALLOWED_ORIGIN=https://yourstore.myshopify.com

# A random secret string shared between your theme JS and this API
# Generate one at: https://passwordsgenerator.net/ (use 32+ chars, no special chars)
WISHLIST_API_SECRET=your_random_secret_here_32chars

# A separate secret for the one-time /api/setup endpoint
SETUP_SECRET=your_setup_secret_here
